# Required
OPENAI_API_KEY=sk-...

# Optional: gate all API routes (send as x-api-key or Authorization: Bearer)
API_SECRET=

# Vector store
CHROMA_URL=http://localhost:8000

# Optional: higher GitHub API rate limits / private-repo metadata
GITHUB_TOKEN=

# Resource limits
MAX_ZIP_BYTES=52428800
MAX_FILE_BYTES=524288
MAX_FILES=2000
MAX_TOTAL_CHARS=5000000
MAX_CHUNKS=5000

# Repo access token lifetime (ms)
REPO_TTL_MS=86400000

# Rate limits
RATE_LIMIT_INGEST_PER_HOUR=10
RATE_LIMIT_ASK_PER_MINUTE=30
RATE_LIMIT_SUMMARY_PER_MINUTE=10
RATE_LIMIT_CONTACT_PER_HOUR=5

# Large-repo embedding / Chroma tuning
EMBEDDING_BATCH_DELAY_MS=1200
CHROMA_BATCH_SIZE=5000
